{
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/moonshotai/kimi-k2.5:online"
      },
      "thinkingDefault": "off",
      "verboseDefault": "off"
    }
  },
  "models": {
    "providers": {
      "openrouter": {
        "baseUrl": "https://openrouter.ai/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "moonshotai/kimi-k2.5:online",
            "name": "Kimi K2.5",
            "contextWindow": 131072,
            "maxTokens": 8192,
            "input": [
              "text"
            ],
            "compat": {
              "maxTokensField": "max_tokens"
            }
          }
        ]
      }
    }
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "openclaw",
    "noSandbox": true,
    "headless": true,
    "executablePath": "/usr/bin/chromium",
    "profiles": {}
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "trustedProxies": [
      "172.16.0.0/12",
      "10.0.0.0/8",
      "192.168.0.0/16"
    ],
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": [
        "https://heyron.ai",
        "https://www.heyron.ai"
      ],
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "skills": {
    "allowBundled": []
  },
  "web": {
    "enabled": true
  },
  "channels": {},
  "tools": {
    "web": {},
    "exec": {},
    "sessions": {
      "visibility": "all"
    },
    "agentToAgent": {
      "enabled": true
    }
  }
}